# Copy to .env (gitignored) for the OFFLINE pipeline (Tier A). The SPA needs none of this.

# OpenAlex "polite pool" contact email — NOT a secret, just identifies your traffic.
OPENALEX_EMAIL=you@example.com

# LLM classifier (spec §7). Leave blank to run the keyword-seed filter only
# (no precision pass). The pipeline degrades gracefully without a key.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001

# Optional Semantic Scholar key (higher rate limits; works without one).
SEMANTIC_SCHOLAR_API_KEY=
